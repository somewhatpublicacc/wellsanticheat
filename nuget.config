<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- clear so a machine-wide nuget.config can't remove these -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- BepInEx.Unity.IL2CPP, BepInEx.IL2CPP.MSBuild and the real AmongUs.GameLibs.Steam live here -->
    <add key="BepInEx" value="https://nuget.bepinex.dev/v3/index.json" allowInsecureConnections="True" />
  </packageSources>
</configuration>
